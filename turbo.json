{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "tokens": {
      "outputs": ["generated/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "generated/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
