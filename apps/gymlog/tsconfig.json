{
  "extends": "@config/tsconfig/next.json",
  "compilerOptions": {
    "paths": {
      "@app/*": ["./src/app/*"],
      "@views/*": ["./src/views/*"],
      "@widgets/*": ["./src/widgets/*"],
      "@features/*": ["./src/features/*"],
      "@entities/*": ["./src/entities/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
