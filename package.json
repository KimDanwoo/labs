{
  "name": "danwoo-lab",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "tokens": "turbo run tokens",
    "new-app": "node scripts/new-app.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\""
  },
  "prettier": "@repo/prettier-config",
  "devDependencies": {
    "@repo/prettier-config": "workspace:*",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "next": "catalog:",
      "eslint-config-next": "catalog:"
    }
  }
}
