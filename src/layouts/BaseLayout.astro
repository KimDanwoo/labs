---
import '~/styles/global.css'

interface Props {
  title?: string
  description?: string
  thumbnail?: string
  url?: string
}

const {
  title = 'blog.danwoo',
  description = '기록하고 공유합니다',
  thumbnail,
  url
} = Astro.props

const siteTitle = 'blog.danwoo'
const siteUrl = 'https://danwoo-dev.netlify.app'
const metaUrl = url ?? siteUrl
const metaThumbnail = thumbnail ?? `${siteUrl}/og.png`
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={metaUrl} />
    <link rel="icon" href="/favicon.png" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={metaThumbnail} />
    <meta property="og:url" content={metaUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaThumbnail} />
    <meta
      name="google-site-verification"
      content="-kohA7qdl_10fMUGOMlZ7EArpE6vOn0DHONUwImizX8"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <div id="scroll-sentinel" class="absolute top-0 h-0 w-full pointer-events-none"></div>

    <header
      id="main-header"
      class="sticky top-0 z-[9999] w-full bg-white/95 backdrop-blur-sm border-b border-grey-3 transition-shadow duration-200"
    >
      <div class="max-w-[720px] mx-auto flex items-center px-5 h-14 sm:h-16">
        <a
          class="mr-auto text-green-0 text-lg font-bold tracking-tight hover:text-green-1 transition-colors"
          href="/"
        >
          Dansoon
        </a>
        <nav class="flex items-center gap-5 sm:gap-7">
          <a
            class="text-grey-0 text-sm font-medium hover:text-[#1c1c1c] transition-colors"
            href="https://docs.google.com/document/d/1_oia6H3WisAHsGNJWZAYqru9pHUXovRNAaRJcZn5UBU/preview"
            target="_blank"
            rel="noopener noreferrer"
          >ME</a>
          <a
            class="text-grey-0 text-sm font-medium hover:text-[#1c1c1c] transition-colors"
            href="/"
          >BLOG</a>
          <a
            class="text-grey-0 text-sm font-medium hover:text-[#1c1c1c] transition-colors"
            href="https://github.com/KimDanwoo"
            target="_blank"
            rel="noopener noreferrer"
          >GITHUB</a>
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-[720px] w-full mx-auto px-5 py-8 sm:py-12">
      <slot />
    </main>

    <footer class="border-t border-grey-3">
      <div class="max-w-[720px] mx-auto px-5 py-8 flex items-center justify-between text-sm text-grey-1">
        <span>© {new Date().getFullYear()} <a class="font-semibold text-grey-0 hover:text-green-0 transition-colors" href="https://github.com/KimDanwoo">Danwoo</a></span>
        <span>Built with <a class="font-semibold text-grey-0 hover:text-green-0 transition-colors" href="https://astro.build">Astro</a></span>
      </div>
    </footer>

    <script>
      const sentinel = document.getElementById('scroll-sentinel')
      const header = document.getElementById('main-header')
      if (sentinel && header) {
        const observer = new IntersectionObserver(
          ([entry]) => {
            header.classList.toggle('shadow-sm', !entry.isIntersecting)
          },
          { threshold: 1.0 }
        )
        observer.observe(sentinel)
      }
    </script>
  </body>
</html>
