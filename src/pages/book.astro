---
import { getCollection } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import PostList from '~/components/Main/PostList'

const allPosts = await getCollection('book')
const bookPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map(post => {
    const slug = post.id.replace(/\/index\.md$/, '').replace(/\.md$/, '')
    return {
      title: post.data.title,
      description: post.data.description,
      category: post.data.category ?? '',
      isHidden: false,
      thumbnail: post.data.thumbnail ? { src: post.data.thumbnail.src } : null,
      url: `/${slug}/`,
      publishedAt: post.data.date.toLocaleDateString('ko-KR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })
    }
  })
---

<BaseLayout title="베스트셀러 | blog.danwoo" description="알라딘, 리디 베스트셀러 주간 리포트">
  <PostList posts={bookPosts} />
</BaseLayout>
