---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import Utterances from '~/components/Common/Utterances'

export async function getStaticPaths() {
  const techPosts = await getCollection('tech')
  return techPosts.map(post => {
    const slug = post.id.replace(/\/index\.md$/, '').replace(/\.md$/, '')
    return { params: { slug }, props: { post } }
  })
}

type Props = { post: CollectionEntry<'tech'> }

const { post } = Astro.props
const { Content } = await render(post)
const { title, description, date, thumbnail, category } = post.data
const slug = post.id.replace(/\/index\.md$/, '').replace(/\.md$/, '')
const url = `https://danwoo-dev.netlify.app/tech/${slug}/`
const isIntroPage = title === '🧑🏻‍💻 frontend 김단우'
const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric'
})
---

<BaseLayout title={title} description={description} url={url} thumbnail={thumbnail?.src}>
  <article class="w-full" itemscope itemtype="http://schema.org/Article">
    <header class="w-full mb-10">
      <a href="/" class="article-back inline-flex items-center gap-1.5 text-sm mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        목록으로
      </a>

      <div class="flex items-center gap-2 text-xs mb-3">
        {category && <span class="post-card-category">{category}</span>}
        {category && <span style="color:var(--border)">·</span>}
        <time style="color:var(--text-muted)">{formattedDate}</time>
      </div>

      <h1 class="article-title" itemprop="headline">{title}</h1>

      {description && (
        <p class="article-desc">{description}</p>
      )}

      {thumbnail && !isIntroPage && (
        <img class="article-thumb" src={thumbnail.src} alt="" />
      )}
    </header>

    <div class="article-body prose max-w-none">
      <Content />
    </div>

    {!isIntroPage && (
      <div class="mt-16 pt-10" style="border-top:1px solid var(--border)">
        <Utterances client:load />
      </div>
    )}
  </article>
</BaseLayout>

<script>
  function wrapTables() {
    document.querySelectorAll('.article-body table').forEach(table => {
      if (table.parentElement?.classList.contains('table-wrap')) return
      const wrap = document.createElement('div')
      wrap.className = 'table-wrap'
      wrap.style.overflowX = 'auto'
      wrap.style.webkitOverflowScrolling = 'touch'
      wrap.style.margin = '1.25rem 0'
      table.parentNode!.insertBefore(wrap, table)
      wrap.appendChild(table)
    })
  }
  wrapTables()
  document.addEventListener('astro:after-swap', wrapTables)
</script>

<style>
  .article-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .article-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0 0 1.5rem;
  }

  .article-thumb {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--border);
  }

  .article-body {
    --tw-prose-body:        var(--text-secondary);
    --tw-prose-headings:    var(--text-primary);
    --tw-prose-bold:        var(--text-primary);
    --tw-prose-links:       var(--green);
    --tw-prose-code:        var(--green);
    --tw-prose-pre-bg:      var(--bg-subtle);
    --tw-prose-pre-code:    var(--text-primary);
    --tw-prose-hr:          var(--border);
    --tw-prose-quote-borders: var(--green);
    --tw-prose-quotes:      var(--text-primary);
    --tw-prose-bullets:     var(--border);
    --tw-prose-counters:    var(--text-muted);
    --tw-prose-captions:    var(--text-muted);
    --tw-prose-th-borders:  var(--border);
    --tw-prose-td-borders:  var(--border);

    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .article-body :global(pre) {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 0.875rem;
    overflow-x: auto;
  }

  .article-body :global(:not(pre) > code) {
    background: var(--bg-hover);
    color: var(--green);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    border: 1px solid var(--border);
  }

  .article-body :global(blockquote) {
    background: var(--bg-subtle);
    border-left: 3px solid var(--green);
    border-radius: 0 8px 8px 0;
    padding: 0.75rem 1.25rem;
    font-style: normal;
    color: var(--text-secondary);
  }

  .article-body :global(.table-wrap) {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 8px;
    border: 1px solid var(--border);
    margin: 1.25rem 0;
  }

  .article-body :global(table) {
    width: max-content;
    min-width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .article-body :global(th) {
    background: var(--bg-subtle);
    color: var(--text-primary);
    font-weight: 700;
    border: 1px solid var(--border);
    padding: 0.6rem 0.9rem;
    text-align: left;
    white-space: nowrap;
  }

  .article-body :global(td) {
    border: 1px solid var(--border);
    padding: 0.55rem 0.9rem;
    color: var(--text-secondary);
  }

  .article-body :global(tr:nth-child(even) td) {
    background: var(--bg-subtle);
  }

  @media (max-width: 640px) {
    .article-body :global(th),
    .article-body :global(td) {
      padding: 0.4rem 0.55rem;
      font-size: 0.78rem;
    }
    .article-body :global(blockquote) {
      padding: 0.6rem 0.9rem;
    }
    .article-body :global(pre) {
      font-size: 0.8rem;
      border-radius: 8px;
    }
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .article-body :global(img) {
    border-radius: 10px;
    border: 1px solid var(--border);
  }
</style>
