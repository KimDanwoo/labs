---
import { getCollection } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import MainContent from '~/components/Main/MainContent'

const posts = await getCollection('blog')
const sortedPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map(post => {
    const slug = post.id.replace(/\/index\.md$/, '').replace(/\.md$/, '')
    return {
      title: post.data.title,
      description: post.data.description,
      category: post.data.category ?? '',
      isHidden: post.data.isHidden ?? false,
      thumbnail: post.data.thumbnail ? { src: post.data.thumbnail.src } : null,
      url: `/${slug}/`,
      publishedAt: post.data.date.toLocaleDateString('ko-KR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })
    }
  })
---

<BaseLayout title="김단우 블로그">
  <MainContent posts={sortedPosts} client:load />
</BaseLayout>
